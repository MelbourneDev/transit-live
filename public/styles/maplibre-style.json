{
  "version": 8,
  "name": "Transit-Live Melbourne — Ghibli Edition",
  "metadata": {
    "description": "Pastel Zelda/Animal Crossing aesthetic for MapLibre GL + Protomaps .pmtiles",
    "schema": "protomaps-v3 (OpenMapTiles-compatible)"
  },

  "glyphs": "https://protomaps.github.io/basemaps-assets/fonts/{fontstack}/{range}.pbf",
  "sprite": "https://protomaps.github.io/basemaps-assets/sprites/v4/light",

  "sources": {
    "protomaps": {
      "type": "vector",
      "url": "pmtiles://https://<YOUR_R2_BUCKET>.r2.dev/melbourne.pmtiles",
      "attribution": "© <a href='https://openstreetmap.org'>OpenStreetMap</a> contributors"
    }
  },

  "sky": {
    "sky-color": "#d4eef5",
    "sky-horizon-blend": 0.7,
    "horizon-color": "#e8f5fb",
    "horizon-fog-blend": 0.8,
    "fog-color": "#dff0f7",
    "fog-ground-blend": 0.9,
    "atmosphere-blend": ["interpolate", ["linear"], ["zoom"], 10, 1.0, 14, 0.5]
  },

  "fog": {
    "range": [2, 12],
    "color": "#d4eef5",
    "horizon-blend": 0.08,
    "high-color": "#a8d8e8",
    "space-color": "#7ec8e3",
    "star-intensity": 0.0
  },

  "layers": [

    {
      "id": "background",
      "type": "background",
      "paint": { "background-color": "#dceccf" }
    },

    {
      "id": "earth",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "earth",
      "paint": { "fill-color": "#dceccf" }
    },

    {
      "id": "natural-wood",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "natural",
      "filter": ["in", "pmap:kind", "wood", "forest", "park", "grass", "meadow", "scrub"],
      "paint": {
        "fill-color": [
          "match", ["get", "pmap:kind"],
          ["wood", "forest"], "#b5d99c",
          ["park", "grass", "meadow"], "#c8e6b4",
          "scrub", "#c2dba0",
          "#c8e6b4"
        ],
        "fill-opacity": 0.85
      }
    },

    {
      "id": "landuse-residential",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "landuse",
      "filter": ["in", "pmap:kind", "residential", "neighbourhood"],
      "paint": { "fill-color": "#e8f0dc", "fill-opacity": 0.6 }
    },

    {
      "id": "landuse-commercial",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "landuse",
      "filter": ["in", "pmap:kind", "commercial", "retail", "industrial"],
      "paint": { "fill-color": "#f0e8d8", "fill-opacity": 0.5 }
    },

    {
      "id": "landuse-school",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "landuse",
      "filter": ["in", "pmap:kind", "school", "university", "college"],
      "paint": { "fill-color": "#fdf0d0", "fill-opacity": 0.6 }
    },

    {
      "id": "water",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "water",
      "paint": {
        "fill-color": [
          "interpolate", ["linear"], ["zoom"],
          8,  "#a8d8e8",
          14, "#90cde0"
        ],
        "fill-opacity": 1,
        "fill-antialias": true
      }
    },

    {
      "id": "water-stroke",
      "type": "line",
      "source": "protomaps",
      "source-layer": "water",
      "paint": {
        "line-color": "#82c4d8",
        "line-width": 0.8,
        "line-opacity": 0.6
      }
    },

    {
      "id": "roads-tunnel-case",
      "type": "line",
      "source": "protomaps",
      "source-layer": "roads",
      "filter": ["==", "pmap:tunnel", 1],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#c8d8b8",
        "line-width": ["interpolate", ["linear"], ["zoom"], 10, 1, 16, 6],
        "line-dasharray": [2, 1],
        "line-opacity": 0.5
      }
    },

    {
      "id": "roads-path",
      "type": "line",
      "source": "protomaps",
      "source-layer": "roads",
      "filter": ["in", "pmap:kind", "path", "track", "footway", "cycleway", "steps"],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#b8d4a0",
        "line-width": ["interpolate", ["linear"], ["zoom"], 13, 0.5, 18, 2],
        "line-dasharray": [1, 2],
        "line-opacity": 0.7
      }
    },

    {
      "id": "roads-minor",
      "type": "line",
      "source": "protomaps",
      "source-layer": "roads",
      "filter": ["in", "pmap:kind", "minor_road", "service"],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#f5f0e0",
        "line-width": ["interpolate", ["linear"], ["zoom"], 12, 0.5, 16, 3.5, 18, 6],
        "line-opacity": 0.9
      }
    },

    {
      "id": "roads-minor-case",
      "type": "line",
      "source": "protomaps",
      "source-layer": "roads",
      "filter": ["in", "pmap:kind", "minor_road", "service"],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#d8cbb4",
        "line-width": ["interpolate", ["linear"], ["zoom"], 12, 1, 16, 5, 18, 8],
        "line-opacity": 0.4,
        "line-gap-width": 0
      }
    },

    {
      "id": "roads-medium",
      "type": "line",
      "source": "protomaps",
      "source-layer": "roads",
      "filter": ["in", "pmap:kind", "medium_road"],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#fdf8ea",
        "line-width": ["interpolate", ["linear"], ["zoom"], 10, 0.8, 14, 3, 18, 10],
        "line-opacity": 1
      }
    },

    {
      "id": "roads-major",
      "type": "line",
      "source": "protomaps",
      "source-layer": "roads",
      "filter": ["in", "pmap:kind", "major_road", "highway", "trunk"],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#fef0b8",
        "line-width": ["interpolate", ["linear"], ["zoom"], 8, 1, 12, 4, 18, 14],
        "line-opacity": 1
      }
    },

    {
      "id": "roads-major-case",
      "type": "line",
      "source": "protomaps",
      "source-layer": "roads",
      "filter": ["in", "pmap:kind", "major_road", "highway", "trunk"],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#e8c878",
        "line-width": ["interpolate", ["linear"], ["zoom"], 8, 2.5, 12, 6, 18, 18],
        "line-gap-width": 0,
        "line-opacity": 0.4
      }
    },

    {
      "id": "transit-rail",
      "type": "line",
      "source": "protomaps",
      "source-layer": "transit",
      "filter": ["in", "pmap:kind", "rail", "subway"],
      "layout": { "line-cap": "butt", "line-join": "miter" },
      "paint": {
        "line-color": "#94aed4",
        "line-width": ["interpolate", ["linear"], ["zoom"], 10, 1, 16, 3],
        "line-opacity": 0.8
      }
    },

    {
      "id": "transit-rail-dash",
      "type": "line",
      "source": "protomaps",
      "source-layer": "transit",
      "filter": ["in", "pmap:kind", "rail", "subway"],
      "layout": { "line-cap": "butt" },
      "paint": {
        "line-color": "#ffffff",
        "line-width": ["interpolate", ["linear"], ["zoom"], 10, 0.5, 16, 1.5],
        "line-dasharray": [3, 3],
        "line-opacity": 0.5
      }
    },

    {
      "id": "buildings-footprint",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "buildings",
      "maxzoom": 14,
      "paint": {
        "fill-color": "#f8f2dc",
        "fill-opacity": ["interpolate", ["linear"], ["zoom"], 11, 0, 14, 0.7]
      }
    },

    {
      "id": "buildings-3d",
      "type": "fill-extrusion",
      "source": "protomaps",
      "source-layer": "buildings",
      "minzoom": 14,
      "paint": {
        "fill-extrusion-color": [
          "interpolate", ["linear"],
          ["coalesce", ["get", "height"], ["get", "render_height"], 0],
          0,   "#f8f2dc",
          20,  "#fdf5e0",
          60,  "#fff8e8",
          120, "#fffaf0"
        ],
        "fill-extrusion-height": [
          "coalesce", ["get", "height"], ["get", "render_height"],
          ["*", ["coalesce", ["get", "levels"], ["get", "render_min_height"], 1], 3.5]
        ],
        "fill-extrusion-base": [
          "coalesce", ["get", "min_height"], ["get", "render_min_height"], 0
        ],
        "fill-extrusion-opacity": [
          "interpolate", ["linear"], ["zoom"],
          14, 0,
          15, 0.75,
          18, 0.9
        ],
        "fill-extrusion-vertical-gradient": true
      }
    },

    {
      "id": "water-label",
      "type": "symbol",
      "source": "protomaps",
      "source-layer": "places",
      "filter": ["==", "pmap:kind", "water"],
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["Noto Sans Italic"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 8, 10, 14, 14],
        "text-max-width": 8
      },
      "paint": {
        "text-color": "#4a8fa8",
        "text-halo-color": "#ddf0f8",
        "text-halo-width": 1.5,
        "text-opacity": 0.85
      }
    },

    {
      "id": "roads-label",
      "type": "symbol",
      "source": "protomaps",
      "source-layer": "roads",
      "minzoom": 14,
      "filter": ["in", "pmap:kind", "major_road", "medium_road"],
      "layout": {
        "symbol-placement": "line",
        "text-field": ["get", "name"],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 14, 10, 18, 13],
        "text-max-angle": 30,
        "text-offset": [0, 0.8]
      },
      "paint": {
        "text-color": "#8a7a5a",
        "text-halo-color": "#fdf8ea",
        "text-halo-width": 1.8
      }
    },

    {
      "id": "place-suburb",
      "type": "symbol",
      "source": "protomaps",
      "source-layer": "places",
      "filter": ["in", "pmap:kind", "neighbourhood", "suburb", "quarter"],
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 11, 10, 15, 14],
        "text-transform": "uppercase",
        "text-letter-spacing": 0.12,
        "text-max-width": 6
      },
      "paint": {
        "text-color": "#7a9060",
        "text-halo-color": "#e8f0dc",
        "text-halo-width": 1.5,
        "text-opacity": ["interpolate", ["linear"], ["zoom"], 11, 0, 13, 1]
      }
    },

    {
      "id": "place-town",
      "type": "symbol",
      "source": "protomaps",
      "source-layer": "places",
      "filter": ["in", "pmap:kind", "town", "village"],
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["Noto Sans Bold"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 9, 11, 14, 16],
        "text-anchor": "center"
      },
      "paint": {
        "text-color": "#4a6040",
        "text-halo-color": "#dceccf",
        "text-halo-width": 2
      }
    },

    {
      "id": "place-city",
      "type": "symbol",
      "source": "protomaps",
      "source-layer": "places",
      "filter": ["in", "pmap:kind", "city"],
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["Noto Sans Bold"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 7, 12, 12, 20],
        "text-anchor": "center",
        "text-max-width": 8
      },
      "paint": {
        "text-color": "#2e4830",
        "text-halo-color": "#dceccf",
        "text-halo-width": 2.5
      }
    },

    {
      "id": "navigation-route-glow-outer",
      "type": "line",
      "source": "navigation-route",
      "layout": { "line-cap": "round", "line-join": "round", "visibility": "none" },
      "paint": {
        "line-color": "#7dd4f8",
        "line-width": 18,
        "line-opacity": 0.2,
        "line-blur": 6
      }
    },
    {
      "id": "navigation-route-glow-mid",
      "type": "line",
      "source": "navigation-route",
      "layout": { "line-cap": "round", "line-join": "round", "visibility": "none" },
      "paint": {
        "line-color": "#4fc3f7",
        "line-width": 10,
        "line-opacity": 0.4,
        "line-blur": 2
      }
    },
    {
      "id": "navigation-route-core",
      "type": "line",
      "source": "navigation-route",
      "layout": { "line-cap": "round", "line-join": "round", "visibility": "none" },
      "paint": {
        "line-color": "#a8d8e8",
        "line-width": 5,
        "line-opacity": 0.95,
        "line-gradient": [
          "interpolate", ["linear"], ["line-progress"],
          0,   "#5bc8f5",
          0.25,"#81d4fa",
          0.5, "#a8e8c8",
          0.75,"#b8f0d0",
          1,   "#c8f8d8"
        ]
      }
    },
    {
      "id": "navigation-route-dash",
      "type": "line",
      "source": "navigation-route",
      "layout": { "line-cap": "round", "line-join": "round", "visibility": "none" },
      "paint": {
        "line-color": "#ffffff",
        "line-width": 2,
        "line-opacity": 0.8,
        "line-dasharray": [0, 4, 2, 4]
      }
    }
  ]
}
